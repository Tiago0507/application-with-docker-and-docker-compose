# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=devboard
POSTGRES_PASSWORD=changeme
POSTGRES_DB=devboard
POSTGRES_PORT=5432

# ── backend-api (FastAPI) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://devboard:changeme@postgres:5432/devboard
REDIS_URL=redis://redis:6379/0
METRICS_SERVICE_URL=http://backend-metrics:3001
DEBUG=false

# ── backend-metrics (NestJS) ───────────────────────────────────────────────────
METRICS_DATABASE_URL=postgresql://devboard:changeme@postgres:5432/devboard_metrics
NODE_ENV=production
PORT=3001

# ── pgAdmin ────────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@devboard.local
PGADMIN_DEFAULT_PASSWORD=changeme
PGADMIN_PORT=5050
